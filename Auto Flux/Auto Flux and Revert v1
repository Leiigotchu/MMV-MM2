local function GetBracket(ping)
    if    ping <= 50  then return 1
    elseif ping <= 100 then return 2
    elseif ping <= 150 then return 3
    elseif ping <= 200 then return 4
    elseif ping <= 300 then return 5
    elseif ping <= 400 then return 6
    elseif ping <= 600 then return 7
    else                    return 8
    end
end

local tierOffset = {High = 0, Mid = 25, Low = 50}

local function GetConfig(ping)
    local weapon = gunMode and "Gun" or "Knife"

    local target
    if     superSpike  then target = "Spike"
    elseif spikeMode   then target = "Spike"
    elseif antiMini    then target = "Mini"
    elseif antiJumper  then target = "Jumper"
    elseif antiZigzag  then target = "Zigzag"
    else                    target = "Universal"
    end

    local bracket = GetBracket(ping)
    local cfg = configs[weapon][target][bracket]

    local offset = tierOffset[perfTier] or 0
    local result = {}
    for k, v in pairs(cfg) do result[k] = v end
    result.Int = result.Int + offset

    if upgrade then
        result.H = math.floor(result.H * 1.10)
        result.V = math.floor(result.V * 1.10)
    end

    if superSpike then
        result.H = math.min(math.floor(result.H * 1.20), 350)
        result.V = math.min(math.floor(result.V * 1.20), 350)
        result.Int = math.max(result.Int - 15, 60)
    end

    return result
end

local function Apply(cfg)
    if locked then return end

    if not internal_shared["RevertSettings_PrioritizeYourPing"] then
        gpl_preset[1]()
    end

    local wantJump = antiJumper
    if internal_shared["RevertSettings_PredictJump"] ~= wantJump then
        gpl_preset[2]()
    end

    if not internal_shared["RevertSettings_PredictLag"] then
        gpl_preset[3]()
    end

    gpl_preset[4](cfg.Sim)
    gpl_preset[5](cfg.Int)
    gpl_preset[7](cfg.X)
    gpl_preset[8](cfg.Y)
    gpl_preset[9](cfg.Z)
    gpl_preset[10](cfg.H)
    gpl_preset[11](cfg.V)
end

local function SetFPSBoost(state)
    fpsBoost = state

    Lighting.GlobalShadows  = not state and origShadows or false
    Lighting.OutdoorAmbient = not state and origAmbient or Color3.fromRGB(128, 128, 128)

    if Terrain then
        Terrain.WaterWaveSize     = state and 0 or 0.15
        Terrain.WaterWaveSpeed    = state and 0 or 10
        Terrain.WaterReflectance  = state and 0 or 1
        Terrain.WaterTransparency = state and 0 or 1
    end
end

local function CreateMonitor()
    if _G.FluxGui then _G.FluxGui:Destroy() end

    local gui = Instance.new("ScreenGui")
    gui.Name   = "AutoRevertFlux"
    gui.Parent = game.CoreGui
    _G.FluxGui = gui

    local function MakeLabel(yPos)
        local lbl = Instance.new("TextLabel")
        lbl.Size                   = UDim2.new(0, 220, 0, 25)
        lbl.Position               = UDim2.new(0.75, 0, 0, yPos)
        lbl.BackgroundTransparency = 1
        lbl.Font                   = Enum.Font.Code
        lbl.TextXAlignment         = Enum.TextXAlignment.Right
        lbl.TextSize               = 18
        lbl.TextColor3             = Color3.fromRGB(255, 255, 255)
        lbl.Parent                 = gui
        return lbl
    end

    local pingLabel    = MakeLabel(40)
    local fpsLabel     = MakeLabel(65)
    local modeLabel    = MakeLabel(90)
    local profileLabel = MakeLabel(115)

    updateConnection = RunService.RenderStepped:Connect(function(dt)
        if not monitorEnabled then
            updateConnection:Disconnect()
            return
        end

        local ping = GetPing()
        local fps  = math.floor(1 / dt)

        local weapon = gunMode and "Gun" or "Knife"
        local target = (superSpike and "SuperSpike")
            or (spikeMode and "Spike")
            or (antiMini and "Mini")
            or (antiJumper and "Jumper")
            or (antiZigzag and "Zigzag")
            or "Universal"

        pingLabel.Text    = "Ping: " .. ping .. "ms"
        fpsLabel.Text     = "FPS: "  .. fps
        modeLabel.Text    = weapon .. " / " .. target .. " / " .. perfTier
        profileLabel.Text = "Profile: " .. currentProfile
    end)
end

task.spawn(function()
    while task.wait(2) do
        if not enabled then continue end

        local rawPing = GetPing()
        RecordPing(rawPing)

        local pingToUse
        if superSpike then
            pingToUse = GetMaxPing() + 150
        elseif spikeMode then
            pingToUse = GetMaxPing()
        else
            pingToUse = rawPing
        end

        local cfg = GetConfig(pingToUse)

        if currentProfile ~= cfg.Name then
            Apply(cfg)
            currentProfile = cfg.Name
        end
    end
end)

