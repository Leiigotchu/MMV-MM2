local pingHistory = {}
local HISTORY_SIZE = 8

local function RecordPing(p)
    table.insert(pingHistory, p)
    if #pingHistory > HISTORY_SIZE then
        table.remove(pingHistory, 1)
    end
end

local function GetMaxPing()
    local m = 0
    for _, v in ipairs(pingHistory) do
        if v > m then m = v end
    end
    return m
end

local function GetPing()
    local ping = LocalPlayer:GetNetworkPing()
    return math.floor((ping > 0 and ping or 0.06) * 1000)
end

